<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.InnerShadow?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.paint.Color?>

<AnchorPane prefHeight="571.0"
            prefWidth="894.0"
            stylesheets="@style.css"
            xmlns="http://javafx.com/javafx/20.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.csc325_firebase_webview_auth.view.AccessFBView">

    <children>

        <MenuBar layoutY="1.0" prefHeight="27.0" prefWidth="894.0">
            <menus>

                <Menu mnemonicParsing="false" text="File">
                    <items>
                        <MenuItem mnemonicParsing="false" text="Login" onAction="#openLogin"/>
                        <MenuItem mnemonicParsing="false" text="Register" onAction="#openRegister"/>
                        <MenuItem mnemonicParsing="false" text="Read Data" onAction="#readRecord"/>
                    </items>
                </Menu>

                <Menu mnemonicParsing="false" text="Edit">
                    <items>
                        <MenuItem mnemonicParsing="false" text="Add Record" onAction="#addRecord"/>
                        <MenuItem mnemonicParsing="false" text="Read Records" onAction="#readRecord"/>
                    </items>
                </Menu>

                <Menu mnemonicParsing="false" text="Theme">
                    <items>
                        <MenuItem mnemonicParsing="false" text="Default Theme"/>
                    </items>
                </Menu>

                <Menu mnemonicParsing="false" text="Help">
                    <items>
                        <MenuItem mnemonicParsing="false" text="CSC325 Firebase Project"/>
                    </items>
                </Menu>

            </menus>
        </MenuBar>

        <HBox layoutX="6.0" layoutY="28.0" prefHeight="535.0" prefWidth="880.0">

            <children>

                <AnchorPane fx:id="leftPanel"
                            styleClass="leftPane"
                            prefHeight="535.0"
                            prefWidth="130.0">

                    <children>
                        <ImageView fx:id="profileImageView"
                                   fitHeight="120.0"
                                   fitWidth="110.0"
                                   layoutX="10.0"
                                   layoutY="14.0"
                                   pickOnBounds="true"
                                   preserveRatio="true">

                            <effect>
                                <InnerShadow>
                                    <color>
                                        <Color red="0.20652228593826294"
                                               green="0.1679999977350235"
                                               blue="0.6000000238418579"/>
                                    </color>
                                </InnerShadow>
                            </effect>

                            <image>
                                <Image url="@profile_empty.png"/>
                            </image>
                        </ImageView>
                    </children>

                </AnchorPane>

                <VBox prefHeight="535.0" prefWidth="520.0">
                    <children>

                        <TextArea fx:id="outputField"
                                  prefHeight="160.0"
                                  prefWidth="520.0"/>

                        <TableView fx:id="tableView"
                                   prefHeight="375.0"
                                   prefWidth="520.0">

                            <columns>
                                <TableColumn fx:id="nameColumn" prefWidth="170.0" text="Name"/>
                                <TableColumn fx:id="majorColumn" prefWidth="170.0" text="Major"/>
                                <TableColumn fx:id="ageColumn" prefWidth="170.0" text="Age"/>
                            </columns>

                        </TableView>

                    </children>
                </VBox>

                <VBox styleClass="rightPane"
                      prefHeight="535.0"
                      prefWidth="230.0"
                      spacing="10.0">

                    <children>

                        <TextField fx:id="nameField" promptText="Name"/>
                        <TextField fx:id="majorField" promptText="Major"/>
                        <TextField fx:id="ageField" promptText="Age"/>

                        <Region VBox.vgrow="ALWAYS"/>

                        <Button fx:id="readButton"
                                text="Read"
                                onAction="#readRecord"/>

                        <Button fx:id="writeButton"
                                text="Add"
                                onAction="#addRecord"/>

                        <Button text="Upload Picture"
                                onAction="#uploadPicture"/>

                        <Button fx:id="switchroot"
                                text="Switch"
                                onAction="#switchToSecondary"/>

                    </children>

                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>

                </VBox>

            </children>

        </HBox>

    </children>

</AnchorPane>